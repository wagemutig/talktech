---
import Layout from '../layouts/Layout.astro';

const ELEVENLABS_AGENT_ID = import.meta.env.ELEVENLABS_AGENT_ID || 'YOUR_AGENT_ID_HERE';
const isDev = import.meta.env.DEV;
---

<Layout title="TALK-TECH — Technical Conversation Practice">
  <main class="min-h-screen bg-slate-950 flex flex-col items-center justify-center p-6 relative overflow-hidden">
    <!-- Background glow -->
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="absolute top-20 left-10 w-72 h-72 bg-emerald-500 rounded-full blur-3xl" />
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-blue-500 rounded-full blur-3xl" />
    </div>

    <div class="max-w-2xl w-full text-center relative z-10">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/10 rounded-full px-4 py-1.5 text-xs font-medium text-slate-300 mb-8">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse" />
        PHZH × afca.ag — TALK-TECH
      </div>

      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Technical English Practice
      </h1>
      <p class="text-lg text-slate-400 mb-2">
        You are a technical specialist. Mr. Barker, a UK business partner, wants to understand your gearbox assembly.
      </p>
      <p class="text-sm text-slate-500 mb-8">
        Explain it in English. You will answer <strong class="text-emerald-400">10 questions</strong> across 3 difficulty levels.
      </p>

      <!-- Widget container -->
      <div class="glass rounded-2xl p-8 border border-white/10 mb-6">
        <div id="widget-container" class="flex justify-center min-h-[120px] items-center">
          {isDev && ELEVENLABS_AGENT_ID === 'YOUR_AGENT_ID_HERE' ? (
            <div class="text-slate-500 text-sm">
              <p>⚠️ Dev mode: Add your ElevenLabs Agent ID to <code class="bg-slate-800 px-2 py-1 rounded">.env</code></p>
              <p class="mt-2">ELEVENLABS_AGENT_ID=your_agent_id</p>
            </div>
          ) : (
            <elevenlabs-convai agent-id={ELEVENLABS_AGENT_ID} />
          )}
        </div>
      </div>

      <!-- Tips -->
      <div class="grid sm:grid-cols-3 gap-4 text-sm text-slate-500">
        <div class="glass rounded-xl p-4 border border-white/5">
          <div class="text-emerald-400 mb-2">🎯</div>
          <p>Speak clearly and use technical terms</p>
        </div>
        <div class="glass rounded-xl p-4 border border-white/5">
          <div class="text-emerald-400 mb-2">🔄</div>
          <p>Mr. Barker asks follow-ups if unclear</p>
        </div>
        <div class="glass rounded-xl p-4 border border-white/5">
          <div class="text-emerald-400 mb-2">⏱️</div>
          <p>~10 minutes, 10 questions total</p>
        </div>
      </div>

      <!-- Footer -->
      <div class="mt-12 text-xs text-slate-600">
        <p>Built with ElevenLabs Conversational AI • TALK-TECH by PHZH</p>
      </div>
    </div>
  </main>
</Layout>

<script src="https://elevenlabs.io/convai-widget/index.js" async type="text/javascript"></script>
